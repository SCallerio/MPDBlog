# Files generated by Jekyll
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Files generated by Bundler
.bundle/
vendor/
Gemfile.lock

# Gems
*.gem

# Files generated by OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Python virtual environment (see requirements.txt; venv lives outside the repo
# at C:\venvs\MPD_Blog, but ignore any local .venv/ too in case one is created here)
.venv/
__pycache__/
*.pyc

# Downloaded/extracted BSEE raw data (large, regenerated by script/process_bsee_wells.py)
data/raw/
eWellAPDRawData/
eWellAPDRawData.zip
*.ipynb.bak

# Secrets — never commit tokens/keys. Nothing in this repo actually reads
# a .env file (no dotenv loader anywhere); this is just so it's a safe
# place to jot one down locally if you want it, e.g. the GitHub PAT for
# cloudflare/like-counter-worker.js. `*.env` (not just `.env`/`.env.*`) on
# purpose — catches any-name.env too, e.g. mpdblog-like-worker-token.env.
*.env

# Wrangler's local CLI cache/account state (Cloudflare account id, etc.)
# — tool-generated, not source, and not something to publish either.
.wrangler/
cloudflare/.wrangler/
